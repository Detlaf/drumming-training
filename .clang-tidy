---
# clang-tidy configuration for drumming-training.
#
# Bundled (third_party/rtmidi) and fetched (SFML, Catch2) sources are excluded
# in CI via the file list passed to run-clang-tidy, so these checks only apply
# to our own code in src/, include/, tools/ and tests/.
Checks: >
  bugprone-*,
  performance-*,
  modernize-*,
  readability-*,
  clang-analyzer-*,
  -modernize-use-trailing-return-type,
  -readability-magic-numbers,
  -readability-identifier-length,
  -readability-braces-around-statements,
  -readability-function-cognitive-complexity,
  -bugprone-easily-swappable-parameters

WarningsAsErrors: ''

HeaderFilterRegex: 'include/drumming/.*'

FormatStyle: none
